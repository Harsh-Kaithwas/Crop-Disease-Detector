<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9F7">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="42dp"
        app:cardBackgroundColor="#2E7D32"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Expert Mode (एक्सपर्ट मोड)"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <GridLayout
        android:id="@+id/expertGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintVertical_bias="0.3">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHistory"
            style="@style/ExpertCardStyle">
            <LinearLayout style="@style/ExpertCardContent">
                <ImageView
                    android:src="@drawable/ic_history"
                    style="@style/ExpertIconStyle" />
                <TextView
                    android:text="History\n(इतिहास)"
                    style="@style/ExpertTextStyle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWeather"
            style="@style/ExpertCardStyle">
            <LinearLayout style="@style/ExpertCardContent">
                <ImageView
                    android:src="@drawable/ic_weather"
                    style="@style/ExpertIconStyle" />
                <TextView
                    android:text="Weather\n(मौसम)"
                    style="@style/ExpertTextStyle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMandi"
            style="@style/ExpertCardStyle">
            <LinearLayout style="@style/ExpertCardContent">
                <ImageView
                    android:src="@drawable/ic_mandi"
                    style="@style/ExpertIconStyle" />
                <TextView
                    android:text="Mandi Rates\n(मंडी भाव)"
                    style="@style/ExpertTextStyle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCrops"
            style="@style/ExpertCardStyle">
            <LinearLayout style="@style/ExpertCardContent">
                <ImageView
                    android:src="@drawable/ic_crops"
                    style="@style/ExpertIconStyle" />
                <TextView
                    android:text="Crop Details\n(फसल जानकारी)"
                    style="@style/ExpertTextStyle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSchemes"
            style="@style/ExpertCardStyle">
            <LinearLayout style="@style/ExpertCardContent">
                <ImageView
                    android:src="@drawable/ic_schemes"
                    style="@style/ExpertIconStyle" />
                <TextView
                    android:text="Govt Schemes\n(सरकारी योजना)"
                    style="@style/ExpertTextStyle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEarning"
            style="@style/ExpertCardStyle">
            <LinearLayout style="@style/ExpertCardContent">
                <ImageView
                    android:src="@drawable/ic_earning"
                    style="@style/ExpertIconStyle" />
                <TextView
                    android:text="Earnings\n(कमाई का हिसाब)"
                    style="@style/ExpertTextStyle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>